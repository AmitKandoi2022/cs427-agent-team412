+    public static void main(final String[] args) throws IOException {
+        Statement cu = StaticJavaParser.parseStatement(
+                "{String str = super.toString();\n"
+                + "                int len = str.length();\n"
+                + "                if (len > 40) return \"OMITTED\";\n"
+                + "                else return str;}");
