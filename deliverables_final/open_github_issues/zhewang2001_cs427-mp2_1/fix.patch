+            ExpressionStmt varDef1 = new ExpressionStmt(varExpr1);
+            body.addStatement(varDef1);
+
+
+            n.addMethod("toString", Modifier.Keyword.PUBLIC).setType("String")
+                    .addAnnotation(ann).setBody(body);
