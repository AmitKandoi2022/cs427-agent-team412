 	\"time\"
 
+var leakCheckWg *sync.WaitGroup
+
+func checkWgDone(wg *sync.WaitGroup) error {
+	c := make(chan struct{})
+	go func() {
+		defer close(c)
+		wg.Wait()
+	}()
+	select {
+	case <-c:
+		return nil
+	case <-time.After(5 * time.Second):
+		return fmt.Errorf(\"goroutines not done after 5s\")
+	}
+}
